<!DOCTYPE html>
<html>
<head>
    <style>
        body { background: transparent; color: white; font-family: 'Courier New', monospace; margin: 0; padding: 10px; overflow: hidden; }
        .container { border: 1px solid #fff; padding: 10px; border-radius: 5px; background: rgba(0,0,0,0.8); }
        .header { font-size: 10px; letter-spacing: 2px; border-bottom: 1px solid rgba(255,255,255,0.3); padding-bottom: 5px; margin-bottom: 10px; display: flex; justify-content: space-between; }
        .member { display: flex; align-items: center; justify-content: space-between; padding: 8px; margin-bottom: 5px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05); }
        .name { font-weight: bold; font-size: 13px; }
        .rating { background: #fff; color: #000; font-size: 10px; padding: 2px 5px; font-weight: 900; }
        @keyframes pulse { 0% { opacity: 0.5; } 50% { opacity: 1; } 100% { opacity: 0.5; } }
        .live-dot { color: #fff; animation: pulse 1.5s infinite; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header"><span>LATEST_RECRUITS</span><span class="live-dot">● LIVE</span></div>
        <div id="list">ACCESSING...</div>
    </div>

    <script>
        async function update() {
            try {
                const response = await fetch('https://api.chess.com/pub/club/chess-society/members');
                const data = await response.json();
                const members = data.all.slice(-3).reverse(); // Get last 3 members
                
                const listDiv = document.getElementById('list');
                listDiv.innerHTML = '';
                
                members.forEach(m => {
                    listDiv.innerHTML += `
                        <div class="member">
                            <span class="name">@${m.username}</span>
                            <span class="rating">MEMBER</span>
                        </div>`;
                });
            } catch (e) { document.getElementById('list').innerText = "OFFLINE"; }
        }
        update();
        setInterval(update, 60000); // Refresh every 60 seconds
    </script>
</body>
</html>
